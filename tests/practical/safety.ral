# Test: things that break in bash but work correctly in ral
# Each section demonstrates a safety property that ral guarantees.

# 1. No word splitting — variables are always one value
let file = 'hello world.txt'
echo $file
# In bash: echo $file → two args "hello" "world.txt" (word split!)
# In ral: echo $file → one arg "hello world.txt"
# Expected: hello world.txt

# 2. No glob expansion on variables
let pattern = '*.txt'
echo $pattern
# In bash: echo $pattern → expands to matching files
# In ral: echo $pattern → literal string "*.txt"
# Expected: *.txt

# 3. Variables in lists preserve structure
let items = ['hello world', 'foo bar']
for $items { |x| echo "[$x]" }
# In bash: for x in "!{array[@]}"; do echo "[$x]"; done
# In bash without quotes: splits on spaces — wrong
# In ral: always correct, no quoting needed
# Expected: [hello world], [foo bar]

# 4. No command injection via variables
let cmd = 'echo hello; rm -rf /'
echo $cmd
# In bash: eval $cmd → executes both commands!
# In ral: $cmd is a string value. echo prints it. No eval.
# Expected: echo hello; rm -rf /

# 5. Immutable bindings — closures are safe
let x = 5
let f = { |_| echo $x }
let x = 10
!{f unit}
# In bash: no closures. Variables are global mutable state.
# In ral: f captured x=5 at definition time.
# Expected: 5

# 6. Structured error handling — not just exit codes
try {
    cat /nonexistent/file ? echo unreachable
} { |err|
    echo "caught: status $err[status]"
}
# In bash: cat /nonexistent; echo $? — status only, no structure
# In ral: error map with status, cmd, stderr, trace
# Expected: caught: status 1

# 7. Scoped environment changes
within [env: [MY_TEST_VAR: hello]] {
    printenv MY_TEST_VAR
}
# MY_TEST_VAR is gone here — no leak
try {
    printenv MY_TEST_VAR
} { |err|
    echo 'MY_TEST_VAR correctly unset'
}
# In bash: export MY_TEST_VAR=hello — leaks to everything
# In ral: scoped, automatic cleanup
# Expected: hello, MY_TEST_VAR correctly unset

# 8. First-class functions
let double = { |x| return $[$x * 2] }
let items = [1, 2, 3, 4, 5]
let result = map $double $items
echo ...$result
# In bash: no lambdas, no map, no first-class functions
# Expected: 2 4 6 8 10

echo 'all safety checks passed'

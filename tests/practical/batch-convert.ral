# Test: batch file conversion pattern.

let dir = '/tmp/al-batch'

mkdir -p "$dir/src" "$dir/out"

# Generate source files
let names = [alice, bob, carol, dave, eve]
for $names { |name|
    echo "name: $name\nrole: user" > "$dir/src/$name"
}

# Convert each: read, uppercase first line, write to output
for $names { |name|
    let content = !{cat "$dir/src/$name" | from-string}
    let xs = lines $content
    let first_line = $xs[0]
    let upper_name = upper $first_line
    echo $upper_name > "$dir/out/$name"
}

# Verify
let results = map { |name|
    let content = !{cat "$dir/out/$name" | from-string}
    return $content
} $names

let nconv = length $results
echo "converted $nconv files"
let first = $results[0]
echo "first: $first"

# Error handling: missing file
try {
    cat "$dir/src/nobody" 2> /dev/null
    ? echo 'should not reach here'
} { |err|
    echo "handled missing file (status $err[status])"
}

# Clean up
rm -rf $dir
if $[not !{exists $dir}] {
    echo 'batch cleanup done'
}

# Test: generate log entries, process them, summarize.

let dir = '/tmp/al-logs'
mkdir -p $dir

# Generate log lines into a single file
let levels = [INFO, WARN, ERROR, INFO, INFO, ERROR, WARN, INFO, ERROR, INFO]
for $levels { |level|
    echo "$level: something happened" >> "$dir/app.log"
}

# Read log file into list of lines
let lines_step = cat "$dir/app.log" | from-lines
let lines = !{step-into-list { return $lines_step }}
let nlines = length $lines
echo "total lines: $nlines"

# Count errors by filtering
let errors = filter { |line| !{match '^ERROR' $line} } $lines
let nerrors = length $errors
echo "errors: $nerrors"

# Count warnings
let warns = filter { |line| !{match '^WARN' $line} } $lines
let nwarns = length $warns
echo "warnings: $nwarns"

# Count total using fold
let total = fold { |acc _| return $[$acc + 1] } 0 $lines
echo "counted: $total"

# Write summary
echo "Log Summary" > "$dir/summary.txt"
echo "Total: $nlines" >> "$dir/summary.txt"
echo "Errors: $nerrors" >> "$dir/summary.txt"
echo "Warnings: $nwarns" >> "$dir/summary.txt"

let summary = cat "$dir/summary.txt"
echo $summary

# Clean up
rm -rf $dir
if $[not !{exists $dir}] {
    echo 'logs cleaned up'
}

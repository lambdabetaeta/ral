#!/usr/bin/env ral

# Test: script arguments via $args

let [name, ...rest] = $args

echo "hello, $name"

if $[!{length $rest} > 0] {
    echo "extra args: $rest"
} {}

# Run as:
#   ral tests/practical/args.ral world
#   Expected: hello, world
#
#   ral tests/practical/args.ral world foo bar
#   Expected: hello, world
#             extra args: [foo, bar]

# Test: create files, write to them, read them back, clean up.

let nums = [1, 2, 3, 4, 5]
let dir = '/tmp/al-file-ops'

mkdir -p $dir

# Create numbered files
for $nums { |n|
    echo "content of file $n" > "$dir/file-$n"
}

# Verify they exist
for $nums { |n|
    if !{is-file "$dir/file-$n"} {
        echo "file $n exists"
    }
}

# Read them back
let contents = map { |n|
    let content = !{cat "$dir/file-$n" | from-string}
    return $content
} $nums
let nread = length $contents
echo "read $nread files"

# Uppercase each file's content
for $nums { |n|
    let original = !{cat "$dir/file-$n" | from-string}
    echo !{upper $original} > "$dir/upper-$n"
}

let sample = !{cat "$dir/upper-3" | from-string}
echo "uppercase: $sample"

# Count all files
let all_files = find $dir -type f | from-lines
let nfiles = length $all_files
echo "total files: $nfiles"

# Clean up
rm -rf $dir
if $[not !{exists $dir}] {
    echo 'cleanup complete'
}

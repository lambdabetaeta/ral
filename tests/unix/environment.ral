# Test: $env, within [env:]

# Read environment
echo $env[HOME]
# Expected: user's home directory

# within [env:] scoped override
within [env: [MY_VAR: hello]] {
    # The override is visible to child processes:
    printenv MY_VAR
}
# Expected: hello

# within [env:] doesn't leak — printenv exits 1 when var is unset, use try
try { printenv MY_VAR } { |_| echo 'MY_VAR correctly unset' }
# Expected: MY_VAR correctly unset

# Nested within [env:]
within [env: [A: 1]] {
    within [env: [B: 2]] {
        printenv A
        printenv B
    }
    # B is gone
    printenv A
}
# Expected: 1, 2, 1

# Test: pipes, redirects, fd numbers, command substitution

# Basic pipe
echo 'hello world' | from-string | upper
# Expected: HELLO WORLD (if upper works as a command)

# Multi-stage pipe: external | external
printf "cherry\napple\nbanana\n" | grep "apple"
# Expected: apple

# Multi-stage pipe: internal | internal over explicit byte boundary
let fruits = ["cherry", "apple", "banana"]
sort-list $fruits | map { |x| echo $x }
# Expected: apple banana cherry (sorted)

# Redirect stdout
echo hello > /tmp/al-test-out.txt
cat /tmp/al-test-out.txt
# Expected: hello

# Redirect stderr — ls /nonexistent fails, use attempt to suppress propagation
attempt { ls /nonexistent 2> /tmp/al-test-err.txt }
cat /tmp/al-test-err.txt
# Expected: error message about /nonexistent

# Redirect stderr to stdout — use attempt since ls will fail
attempt { ls /nonexistent 2>&1 | head -1 }
# Expected: error message

# Append
echo first > /tmp/al-test-append.txt
echo second >> /tmp/al-test-append.txt
cat /tmp/al-test-append.txt
# Expected: first (newline) second

# Command substitution captures stdout
let name = echo alice
echo "name is $name"
# Expected: name is alice

# Trailing newline stripped
let result = echo hello
echo "[$result]"
# Expected: [hello] (no trailing newline)

# from-line strips trailing newline
let b = printf "hello\n"
let s = _decode line $b
if $[not !{equal $s "hello"}] { fail [status: 1] }
echo "from-line: $s"
# Expected: from-line: hello

# from-line preserves internal newlines, strips only the final one
let b2 = printf "foo\nbar\n"
let s2 = _decode line $b2
if $[not !{equal $s2 "foo\nbar"}] { fail [status: 1] }

# from-line on bytes with no trailing newline is a no-op
let b3 = printf "no-newline"
let s3 = _decode line $b3
if $[not !{equal $s3 "no-newline"}] { fail [status: 1] }

# Cleanup
rm /tmp/al-test-out.txt /tmp/al-test-err.txt /tmp/al-test-append.txt

# Test: §10.0 failure propagation

# Sequential: failure stops execution
try {
    cat /nonexistent 2> /dev/null
    echo 'SHOULD NOT REACH'
} { |err|
    echo 'propagation works'
}
# Expected: propagation works

# try suppresses failure
try { cat /nonexistent 2> /dev/null } { |_| echo 'caught' }
# Expected: caught

# ? chain stops on failure
return false ? echo 'should not print'
# Expected: (nothing)

return true ? echo 'chain continued'
# Expected: chain continued

echo 'failure propagation tests done'

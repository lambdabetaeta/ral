# Test: §4.5 all conditional mechanisms

# if with Bool
if true { echo 'if true' }
# Expected: if true

if false { echo 'wrong' } else { echo 'if false' }
# Expected: if false

# if with comparison
if $[5 > 3] { echo 'comparison' }
# Expected: comparison

# ? chain on status
return true ? echo 'chain yes'
# Expected: chain yes

return false ? echo 'chain no'
# Expected: (nothing)

# Value-equality dispatch via if/elsif chains.
let action = 'help'
if !{equal $action 'quit'} { echo quitting }
    elsif !{equal $action 'help'} { echo 'showing help' }
    else { echo unknown }
# Expected: showing help

# Fallback: unmatched value.
let other = 'bogus'
if !{equal $other 'help'} { echo help } else { echo fallback }
# Expected: fallback

echo 'conditional tests done'

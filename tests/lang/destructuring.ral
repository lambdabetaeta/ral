# Test: list destructuring, map destructuring, rest params, nested

# List destructuring
let [first, second, third] = [a, b, c]
echo $first $second $third
# Expected: a b c

# Rest params
let [head, ...tail] = [1, 2, 3, 4, 5]
echo $head
echo !{length $tail}
# Expected: 1, 4

# Map destructuring
let [host: h, port: p] = [host: prod1, port: 8080]
echo $h $p
# Expected: prod1 8080

# Nested destructuring
let [name: n, addr: [city: c]] = [name: alice, addr: [city: london, zip: 'SW1']]
echo "$n lives in $c"
# Expected: alice lives in london

# Destructuring in lambda params
let servers = [
    [host: alpha, port: 80],
    [host: beta, port: 443],
]
for $servers { |[host: h, port: p]|
    echo "$h:$p"
}
# Expected: alpha:80, beta:443 — wait, : is excluded from BARE
# Should be:
for $servers { |[host: h, port: p]|
    echo "$h on port $p"
}
# Expected: alpha on port 80, beta on port 443

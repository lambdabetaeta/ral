# Test: §4.2/§4.3 capture semantics — let binds the return value of its RHS

let assert_eq = { |name expected actual|
    if !{equal $expected $actual} {} else {
        echo "FAIL:" $name "expected:" $expected "actual:" $actual 1>&2
        fail [status: 1]
    }
}

# Block return value: only the last command's bytes are the bound value.
let x = !{ echo one; echo two; echo three }
assert_eq 'block last only' three $x

# Value-returning last command: no capture; value bound directly.
let n = !{ echo hello; length [1, 2, 3] }
assert_eq 'block mixed modes' 3 $n

# Higher-order capture: call-site mode instantiation resolves Var to Bytes.
let f = { |cmd| !$cmd }
let h = f { printf hello }
assert_eq 'higher-order capture' hello $h

# to-json is a dual-channel encoder: returns Bytes, not String.
# Roundtrip via from-json confirms the value is Bytes.
let b = to-json [a: 42]
let obj = !{to-bytes $b | from-json}
assert_eq 'to-json returns bytes (roundtrip)' 42 $obj[a]

# to-bytes: non-UTF-8 roundtrip via from-bytes.
let raw = to-bytes [72, 105]
assert_eq 'to-bytes length' 2 !{length $raw}

echo 'capture semantics done'

# Test: lists, maps, indexing, spread, empty collections

# List basics
let items = [a, b, c]
echo $items[0]
echo $items[2]
# Expected: a, c

# Map basics
let opts = [host: localhost, port: 8080]
echo $opts[host]
echo $opts[port]
# Expected: localhost, 8080

# Nested map with chained indexing
let config = [db: [host: localhost, port: 5432], app: [workers: 4]]
echo $config[db][host]
echo $config[app][workers]
# Expected: localhost, 4

# Spread in maps (override then rest)
let defaults = [host: localhost, port: 8080, workers: 4]
let custom = [port: 9090, ...$defaults]
echo $custom[port]
echo $custom[host]
# Expected: 9090, localhost

# Spread in lists
let a = [1, 2]
let b = [3, 4]
let all = [...$a, ...$b, 5]
echo !{length $all}
# Expected: 5

# Empty collections
let empty_list = []
let empty_map = [:]
echo !{length $empty_list}
# Expected: 0

# Trailing commas
let trailing = [
    a,
    b,
    c,
]
echo !{length $trailing}
# Expected: 3

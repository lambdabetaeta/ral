# Test: if, for, case, and/or/not

# if with else
if $[1 == 1] { echo yes } else { echo no }
# Expected: yes

# if with no else (side effect only)
if !{is-dir /tmp} { echo 'tmp exists' }
# Expected: tmp exists

# for
for [a, b, c] { |x| echo $x }
# Expected: a, b, c (each on a line)

# case dispatch: structural — one clause handles all strings, value
# equality is expressed with nested `if` using `equal`.
let action = 'help'
case $action [
    { |v|
        if !{equal $v 'quit'} { echo quitting }
            elsif !{equal $v 'help'} { echo 'showing help' }
            else { echo unknown }
    }
]
# Expected: showing help

# ? chaining
return true ? echo 'chain continued'
# Expected: chain continued

return false ? echo 'should not print'
# Expected: (nothing — false stops the chain)

# not
if $[not !{is-file /nonexistent}] { echo 'file missing' }
# Expected: file missing

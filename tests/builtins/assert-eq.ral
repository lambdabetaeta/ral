# Test: S12 assert_eq

let assert_eq = { |name expected actual|
    if $[not !{equal $expected $actual}] {
        echo "FAIL:" $name 1>&2
        fail [status: 1]
    }
}

# Passing assertion
assert_eq 'numbers' 42 42
# Expected: (nothing - passes)

assert_eq 'strings' hello hello
# Expected: (nothing)

assert_eq 'lists' [1, 2] [1, 2]
# Expected: (nothing)

# Failing assertion caught by try
try { assert_eq 'mismatch' 42 99 } { |err|
    echo 'assertion failed as expected'
    return unit
}
# Expected: assertion failed as expected

echo 'assert_eq tests done'

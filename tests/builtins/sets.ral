# Test: set operations (maps as sets with Unit values)

let a = [alice: unit, bob: unit, carol: unit]
let b = [bob: unit, dave: unit, eve: unit]

# has — membership
echo !{has $a alice}
# Expected: true
echo !{has $a dave}
# Expected: false

# union
let u = union $a $b
echo !{has $u alice}
echo !{has $u dave}
# Expected: true, true

# intersection
let i = intersection $a $b
echo !{has $i bob}
echo !{has $i alice}
# Expected: true, false

# difference
let d = difference $a $b
echo !{has $d alice}
echo !{has $d bob}
# Expected: true, false

echo 'set tests done'

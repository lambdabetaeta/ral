# Test: §10.1 _try error records

# Success returns status 0
let err = _try { return true }
echo $err[status]
# Expected: 0

# Command failure
let err = _try { cat /nonexistent 2> /dev/null }
echo $err[status]
# Expected: non-zero (1 or 2)

# fail
let err = _try { fail [status: 42] }
echo $err[status]
# Expected: 42

# Error record has col field
let err = _try { fail [status: 1] }
echo !{has $err col}
# Expected: true

# fail with a message via record
let err = _try { fail [status: 7, message: 'custom failure'] }
echo $err[status]
echo $err[message]
# Expected: 7, custom failure

# fail re-raise: $e round-trips status and message
let err = _try {
    try { fail [status: 9, message: 'boom'] } { |e| fail $e }
}
echo $err[status]
echo $err[message]
# Expected: 9, boom

# fail map without message: defaults to "explicit failure"
let err = _try { fail [status: 3] }
echo $err[status]
echo $err[message]
# Expected: 3, explicit failure

# try with handler
try { fail [status: 1] } { |err|
    echo "caught status $err[status]"
}
# Expected: caught status 1

# try success — handler not called
try { return true } { |_| return false }
# Expected: (nothing)

# Nested try
try {
    try { fail [status: 1] } { |err| echo 'inner caught' }
    echo 'continued after inner'
} { |err| echo 'outer caught' }
# Expected: inner caught, continued after inner

# retry
let count = 0
try {
    retry 3 { echo 'trying...'; fail [status: 1] }
} { |err| echo 'retry exhausted' }
# Expected: trying... (3 times), retry exhausted

echo 'try error tests done'

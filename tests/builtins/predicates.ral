# Test: equal, lt, gt, is-empty, and filesystem predicates

# equal — structural equality
echo !{equal hello hello}
# Expected: true
echo !{equal hello world}
# Expected: false
echo !{equal 42 42}
# Expected: true
echo !{equal [1, 2] [1, 2]}
# Expected: true
echo !{equal [1, 2] [1, 3]}
# Expected: false

# lt / gt (lexicographic)
echo !{lt abc def}
# Expected: true
echo !{lt def abc}
# Expected: false
echo !{gt xyz abc}
# Expected: true
echo !{gt abc xyz}
# Expected: false

# is-empty on collections
echo !{is-empty []}
# Expected: true
echo !{is-empty [1, 2]}
# Expected: false
echo !{is-empty [:]}
# Expected: true
echo !{is-empty [a: 1]}
# Expected: false

# is-empty on strings
echo !{is-empty ''}
# Expected: true
echo !{is-empty 'hello'}
# Expected: false

# file-empty on filesystem paths
make-dir /tmp/ral-pred-test
echo !{file-empty /tmp/ral-pred-test}
# Expected: true (empty directory)
echo x > /tmp/ral-pred-test/file
echo !{file-empty /tmp/ral-pred-test}
# Expected: false (directory has entries)
remove-file /tmp/ral-pred-test

# Filesystem predicates
echo !{exists /tmp}
# Expected: true
echo !{is-dir /tmp}
# Expected: true
echo !{is-file /tmp}
# Expected: false
echo !{exists /nonexistent_xyz}
# Expected: false

# elem — list membership
let assert_eq = { |name expected actual|
    if $[not !{equal $expected $actual}] {
        echo "FAIL:" $name 1>&2
        fail [status: 1]
    }
}
let names = [alice, bob, carol]
assert_eq 'elem found'  true  !{elem bob $names}
assert_eq 'elem absent' false !{elem dave $names}
let empty_names = filter { |s| return false } $names
assert_eq 'elem empty'  false !{elem alice $empty_names}

echo 'predicate tests done'

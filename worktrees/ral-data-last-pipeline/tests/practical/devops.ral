# Test: practical devops-style script
# Things you'd actually do in a deployment script

# Build a config map from environment
let config = [
    host: !{hostname | from-string},
    user: !{whoami | from-string},
    tmpdir: /tmp,
]
echo "host: $config[host]"
echo "user: $config[user]"

# Process a list of files with error handling
echo test1 > /tmp/al-test-1.txt
echo test2 > /tmp/al-test-2.txt
echo test3 > /tmp/al-test-3.txt

let files = ['/tmp/al-test-1.txt', '/tmp/al-test-2.txt', '/tmp/al-test-3.txt']
for $files { |f|
    let content = !{cat $f | from-string}
    echo "!{base $f}: $content"
}
# Expected: al-test-1.txt: test1, al-test-2.txt: test2, al-test-3.txt: test3

# Use try for error handling
try {
    cat /nonexistent/file
} { |err|
    echo "caught error with status $err[status]"
}
# Expected: caught error with status 1

# Cleanup with explicit rm
let cleanup_marker = '/tmp/al-cleanup-test'
echo dirty > $cleanup_marker

if !{is-file $cleanup_marker} {
    echo 'cleanup marker exists'
}
rm $cleanup_marker
# Expected: cleanup marker exists

# Chained commands
mkdir -p /tmp/al-chain-test
    ? echo created
    ? ls /tmp/al-chain-test > /dev/null
    ? echo verified
    ? rm -r /tmp/al-chain-test
    ? echo cleaned
# Expected: created, verified, cleaned

# Functional pipeline
let items = [3, 1, 4, 1, 5, 9, 2, 6]
let big = filter { |x| return $[$x > 3] } $items
echo ...$big
# Expected: 4 5 9 6

# Cleanup test files
rm /tmp/al-test-1.txt /tmp/al-test-2.txt /tmp/al-test-3.txt

echo 'all done'

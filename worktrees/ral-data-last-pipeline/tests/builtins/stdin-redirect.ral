# Test: `<file` redirects on builtins parse through Source, not dup2.
#
# Regression: `from-json < file` used to fail under an interactive shell —
# the cached `startup_stdin_tty=true` short-circuited the codec before it
# could read the dup2'd fd 0.  After the structural fix `<file` is parked on
# `shell.io.stdin` as a `Source::File` and the cached-tty gate is consulted
# only when no Source is installed, so the codec reads the file regardless of
# how interactively the shell was launched.

let assert_eq = { |name expected actual|
    if $[not !{equal $expected $actual}] {
        echo "FAIL:" $name "expected:" $expected "actual:" $actual 1>&2
        fail [status: 1]
    }
}

let path = '/tmp/ral-stdin-redirect-test.json'
to-json [host: localhost, port: 8080] > $path

# `from-json` is a primitive; `<file` flows directly through the Exec arm,
# exercising the with_redirects → install_stdin_redirect path.
let obj = from-json < $path
assert_eq 'from-json host' localhost $obj[host]
assert_eq 'from-json port' 8080 $obj[port]

rm $path

# fold-lines also takes `<file` through the same channel.
let lines_path = '/tmp/ral-stdin-redirect-lines.txt'
to-lines [a, b, c] >~ $lines_path
let last = fold-lines { |_ line| $line } '' < $lines_path
assert_eq 'fold-lines last' c $last

rm $lines_path

echo 'stdin-redirect tests done'

# Test: spawn, await, par, race
#
# `await h` resolves a `Handle α` to a record
# `{ value: α, stdout: Bytes, stderr: Bytes, status: Int }`.
# Bytes are not auto-replayed — they sit in the record until the user reads them.

# Basic spawn/await: command-style block (returns Unit, prints to stdout).
let h = spawn { echo from-child }
let r = await $h
echo !{to-bytes $r[stdout] | from-string}
# Expected: from-child

# Value-returning block: bytes still land in stdout, value is the int.
let h = spawn { echo middle ; 42 }
let r = await $h
echo "value=$r[value]"
echo !{to-bytes $r[stdout] | from-string}
# Expected: value=42 / middle

# Multiple spawns
let a = spawn { echo alpha }
let b = spawn { echo beta }
let ra = await $a
let rb = await $b
echo !{to-bytes $ra[stdout] | from-string} !{to-bytes $rb[stdout] | from-string}
# Expected: alpha beta

# Spawn with error: await re-raises; `_try` captures it as an error record.
let h = spawn { /bin/false }
let r = _try { await $h }
echo "child ok=$r[ok] status=$r[status]"
# Expected: child ok=false status=1

# Handles are values — store in a list, then await each.
let handles = map { |x| spawn { $x } } [1, 2, 3]
let values = map { |h| let r = await $h ; $r[value] } $handles
echo $values
# Expected: [1, 2, 3]

# Test: split with regex patterns

# Simple literal split
let result = split '/' 'a/b/c'
echo !{length $result}
echo $result
# Expected: 3, a b c

# Regex split on whitespace
let result = words 'hello   world'
echo !{length $result}
# Expected: 2

# words splits on tabs and newlines too
let result = words "hello\tworld\nfoo"
echo !{length $result}
# Expected: 3

# Split on regex pattern
let result = split '[,;]+' 'a,b;;c,d'
echo $result
# Expected: a b c d

# Split on digits
let result = split '[0-9]+' 'foo123bar456baz'
echo $result
# Expected: foo bar baz

# Lines splits on newline
let result = lines "first\nsecond\nthird"
echo !{length $result}
# Expected: 3

echo 'split regex tests done'

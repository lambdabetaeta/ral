# Test: to-X/from-X codecs and explicit prelude wrappers

let assert_eq = { |name expected actual|
    if $[not !{equal $expected $actual}] {
        echo "FAIL:" $name "expected:" $expected "actual:" $actual 1>&2
        fail [status: 1]
    }
}

# lines from explicit argument
let text = "a\nb\nc"
let lines1 = lines $text
assert_eq 'read-lines length' 3 !{length $lines1}
assert_eq 'read-lines second' b $lines1[1]

# from-json from pipeline bytes
let obj = /bin/echo '{"ok":true,"n":2}' | from-json
assert_eq 'from-json bool' true $obj[ok]
assert_eq 'from-json int' 2 $obj[n]

# to-json from explicit value, piped to from-json
let round = to-json [x: 1, y: true] | from-json
assert_eq 'to-json roundtrip x' 1 $round[x]
assert_eq 'to-json roundtrip y' true $round[y]

# prelude wrappers remain explicit value functions
let parts = split ',' 'a,b,c'
assert_eq 'split explicit length' 3 !{length $parts}
let m = match '.ral$' 'hello.ral'
assert_eq 'match explicit true' true $m
let l = lines "x\ny"
assert_eq 'lines explicit length' 2 !{length $l}
let w = words "one  two\nthree"
assert_eq 'words explicit length' 3 !{length $w}
let w_crlf = lines "one\r\ntwo"
assert_eq 'read-lines crlf length' 2 !{length $w_crlf}

# JSON parsing and line-splitting via codecs / prelude
let p = !{to-string '{"k": 7}' | from-json}
assert_eq 'parse-json wrapper explicit' 7 $p[k]
let rl = lines "u\nv"
assert_eq 'read-lines wrapper explicit' 2 !{length $rl}
# to-X encoders write to the byte channel: value piped to from-X roundtrip
let round2 = [x: 1] | to-json | from-json
assert_eq 'to-json piped roundtrip' 1 $round2[x]
let s = 'abc'
let ra_err = _try { return $s | from-lines }
assert_eq 'from-lines rejects piped value' 1 $ra_err[status]

# bytes codec roundtrip — to-bytes piped to from-bytes gives Value::Bytes
let b = [72, 105]
let b2 = to-bytes $b | from-bytes
assert_eq 'bytes codec length' 2 !{length $b2}
let b2_txt = !{to-bytes $b2 | from-string}
assert_eq 'bytes codec string' 'Hi' $b2_txt

echo 'codec adapter tests done'

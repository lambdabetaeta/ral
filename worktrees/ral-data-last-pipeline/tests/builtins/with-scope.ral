# Test: within [handlers:] scoping and nesting

# Basic handler override
within [handlers: [cat: { echo 'mocked cat' }]] {
    cat anything
}
# Expected: mocked cat

# Override gone after block
try { cat /nonexistent 2> /dev/null } { |_| echo 'real cat failed' }
# Expected: real cat failed

# Nesting: inner wins for same name
within [handlers: [cat: { echo 'outer' }]] {
    within [handlers: [cat: { echo 'inner' }]] {
        cat x
    }
    cat x
}
# Expected: inner, outer

# Different names coexist
within [handlers: [cmd1: { echo 'mock1' }, cmd2: { echo 'mock2' }]] {
    cmd1 x
    cmd2 x
}
# Expected: mock1, mock2

# within handlers does not shadow builtins via classify_command_head
# (handler check fires before builtin dispatch, but builtins are not in
# handler_stack — this tests that 'echo' as a builtin still works normally)
within [handlers: [ls: { return 'overridden' }]] {
    echo 'still real echo'
}
# Expected: still real echo

echo 'with scope tests done'

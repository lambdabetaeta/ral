# Test: map, filter, fold, reduce

let items = [1, 2, 3, 4, 5]

# Map
let doubled = map { |x| return $[$x * 2] } $items
echo $doubled
# Expected: [2, 4, 6, 8, 10]

# Filter
let big = filter { |x| return $[$x > 3] } $items
echo $big
# Expected: [4, 5]

# Fold
let total = fold { |acc x| return $[$acc + $x] } 0 $items
echo $total
# Expected: 15

# Reduce
let product = reduce { |a b| return $[$a * $b] } $items
echo $product
# Expected: 120

# Composition — map then filter
let result = filter { |x| return $[$x > 5] } !{map { |x| return $[$x * 2] } $items}
echo $result
# Expected: [6, 8, 10]

# Practical example: file processing
let files = glob '*.ral'
let names = map { |f| stem $f } $files
echo $names

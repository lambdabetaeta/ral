# Test: bracket indexing, context-sensitive : =, and command arg spreading

# Bracket indexing on maps
let config = [host: prod1, port: 8080]
echo $config[host]
echo $config[port]
# Expected: prod1, 8080

# Nested bracket indexing
let app = [db: [host: localhost, port: 5432], cache: [host: redis, port: 6379]]
echo $app[db][host]
echo $app[cache][port]
# Expected: localhost, 6379

# Bracket indexing in interpolation
echo "database at $app[db][host]:$app[db][port]"
# Expected: database at localhost:5432

# Context-sensitive : — bare word when embedded
echo localhost:5432
# Expected: localhost:5432

echo http://example.com
# Expected: http://example.com

# Context-sensitive = — bare word when embedded
echo -DFOO=bar
# Expected: -DFOO=bar

# : splits for map entries
let opts = [host: local, port: 3000]
echo $opts[host]
# Expected: local

# Command arg spreading
let files = [/tmp, /var]
ls ...$files > /dev/null
echo 'spread worked'
# Expected: spread worked

# Spread in echo
let words = [hello, world]
echo ...$words
# Expected: hello world

# Spread with map function
let nums = [1, 2, 3]
let doubled = map { |x| echo $[$x * 2] } $nums
echo ...$doubled
# Expected: 2 4 6

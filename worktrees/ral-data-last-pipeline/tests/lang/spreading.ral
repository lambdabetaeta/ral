# Test: §4.6 argument spreading and §6 collection spreading

# Spread list into args
let args = [hello, world]
echo ...$args
# Expected: hello world

# Spread empty list
let empty = []
echo ...$empty
# Expected: (empty line)

# Spread in list literal
let combined = [...[1, 2], ...[3, 4]]
echo $combined
# Expected: 1 2 3 4

# Spread in map literal (explicit entries take priority)
let defaults = [host: localhost, port: 8080]
let config = [port: 9090, ...$defaults]
echo $config[port]
echo $config[host]
# Expected: 9090, localhost

echo 'spreading tests done'

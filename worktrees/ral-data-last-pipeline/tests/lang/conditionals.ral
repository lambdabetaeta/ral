# Test: §4.5 all conditional mechanisms

# if with Bool
if true { echo 'if true' }
# Expected: if true

if false { echo 'wrong' } else { echo 'if false' }
# Expected: if false

# if with comparison
if $[5 > 3] { echo 'comparison' }
# Expected: comparison

# ? chain on status
return true ? echo 'chain yes'
# Expected: chain yes

return false ? echo 'chain no'
# Expected: (nothing)

# case dispatch: structural — one clause handles all strings, value
# equality is expressed with nested `if` using `equal`.
let action = 'help'
case $action [
    { |v|
        if !{equal $v 'quit'} { echo quitting }
            elsif !{equal $v 'help'} { echo 'showing help' }
            else { echo unknown }
    }
]
# Expected: showing help

# case with fallback: unmatched value.
case bogus [
    { |v|
        if !{equal $v 'help'} { echo help } else { echo fallback }
    }
]
# Expected: fallback

echo 'conditional tests done'

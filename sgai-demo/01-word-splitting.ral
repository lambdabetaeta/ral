let dir = '/tmp/ral-demo-1'
mkdir -p $dir
echo 'x' > "$dir/alpha.log"
echo 'y' > "$dir/has space.log"
echo 'z' > "$dir/gamma.log"

let dir_contents = ls $dir | from-lines | map {|f| "'$f'\n" } | to-string
echo "contents of $dir:\n $dir_contents"

for !{find $dir -maxdepth 1 -type f | from-lines} { |f|
    echo "removing $f"
    rm $f
}
echo "removing directory $dir"
rmdir $dir
